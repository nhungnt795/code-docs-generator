{
  "info": {
    "name": "VietDocGen API Contract - V2.1",
    "description": "Giao tiếp chính thức giữa Frontend và Backend, hỗ trợ sinh tài liệu từ mã nguồn thô qua GraphRAG.",
    "version": "2.1.0"
  },
  "endpoint": "/api/v1/generate-docs",
  "method": "POST",
  "request": {
    "headers": {
      "Content-Type": "application/json"
    },
    "body_schema": {
      "type": "object",
      "required": ["code", "target_language"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Mã nguồn dạng text cần sinh tài liệu. Không được để rỗng."
        },
        "target_language": {
          "type": "string",
          "enum": ["vi", "en"],
          "description": "Ngôn ngữ tài liệu đầu ra (Mặc định: vi)."
        },
        "options": {
          "type": "object",
          "properties": {
            "use_pgvector_rag": {"type": "boolean", "default": true}
          }
        }
      }
    }
  },
  "response": {
    "success_200": {
      "description": "Xử lý thành công và sinh tài liệu.",
      "body_schema": {
        "type": "object",
        "properties": {
          "status": {"type": "integer", "example": 200},
          "processing_time_ms": {"type": "integer", "example": 11200},
          "metadata": {
            "type": "object",
            "properties": {
              "model": {"type": "string", "example": "Llama-3.1-VietDoc"},
              "vector_db": {"type": "string", "example": "PostgreSQL (pgvector)"}
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "file_name": {"type": "string", "example": "main.py"},
              "readme_markdown": {"type": "string"},
              "retrieved_context": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "similarity_score": {"type": "number", "example": 0.8954},
                    "ast_graph": {"type": "string", "description": "JSON string chứa node và edges của cây AST"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "error_400": {
      "description": "Lỗi dữ liệu đầu vào (Bad Request).",
      "body_schema": {
        "type": "object",
        "properties": {
          "status": {"type": "integer", "example": 400},
          "error_code": {"type": "string", "example": "ERR_001"},
          "message": {"type": "string", "example": "Mã nguồn (code) không được để trống."}
        }
      }
    }
  }
}