# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
DB_USER=docgen
DB_PASS=docgen_password_change_me
DB_NAME=web_and_app_db
DB_HOST=postgres
DB_PORT=5432

# Hoặc dùng URL trực tiếp (ưu tiên hơn 5 biến trên nếu được set)
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# ─────────────────────────────────────────────────────────────
# SMTP (gửi OTP)
# Để trống → OTP sẽ in ra console (chế độ dev, không gửi mail)
# Với Gmail: bật 2FA rồi tạo App Password tại
# https://myaccount.google.com/apppasswords
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your.email@gmail.com
SMTP_PASSWORD=your_app_password_16_chars

# ─────────────────────────────────────────────────────────────
# APP META
# ─────────────────────────────────────────────────────────────
APP_NAME=DocGen VN
APP_URL=https://docgenvn.id.vn

# ─────────────────────────────────────────────────────────────
# AI MODELS (placeholder — điền sau)
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

KAGGLE_MODEL_URL=
KAGGLE_API_TOKEN=
